{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/sebEcho",
        "function": "sebEcho"
      },
      {
        "source": "/validateSEB",
        "function": "validateSEB"
      }
    ]
  }
}
